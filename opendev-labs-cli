#!/bin/bash

# OpenDev Labs CLI Tool
# Comprehensive automation for Vishwa Leader development

PROJECT_DIR="/home/cube/Desktop/syncstack/Vishwa Leader"
PORT=3000

# Print formatting
function print_bold() { echo -e "\033[1m$1\033[0m"; }
function print_success() { echo -e "\033[1;32m$1\033[0m"; }
function print_warning() { echo -e "\033[1;33m$1\033[0m"; }
function print_error() { echo -e "\033[1;31m$1\033[0m"; }

print_help() {
    print_bold "================================================="
    print_bold "       opendev-labs cli (Vishwa Leader)"
    print_bold "================================================="
    echo "Usage: opendev-labs [command]"
    echo ""
    print_bold "Commands:"
    echo "  dev      Starts a clean Next.js dev server (fixes port lock issues)"
    echo "  build    Builds the Next.js project for production"
    echo "  start            Starts the production server"
    echo "  kill             Force-kills any process stuck on port $PORT"
    echo "  openkill [port]  Force-kills any process stuck on the given port (default: $PORT)"
    echo "  clean            Removes the .next cache folder completely"
    echo "  deploy           Commits & pushes to Git and deploys via Vercel CLI"
    echo "  --help           Shows this help menu"
    print_bold "================================================="
}

openkill_port() {
    local target_port=${1:-$PORT}
    echo "Hunting down processes on port $target_port..."
    PIDS=$(lsof -t -i:$target_port 2>/dev/null)
    if [ -n "$PIDS" ]; then
        print_warning "Killing processes on port $target_port: $PIDS"
        kill -9 $PIDS 2>/dev/null
        print_success "Port $target_port is now free!"
    else
        echo "Port $target_port is already free."
    fi
}

start_dev() {
    print_bold "Starting development environment..."
    openkill_port "$PORT"
    echo "Killing any background next servers..."
    pkill -f "next dev" 2>/dev/null
    
    echo "Clearing Next.js dev locks..."
    rm -rf .next/dev

    print_success "Starting fresh Next.js server on port $PORT..."
    cd "$PROJECT_DIR" || exit
    npm run dev
}

build_project() {
    print_bold "Building project for production..."
    cd "$PROJECT_DIR" || exit
    npm run build
}

start_prod() {
    print_bold "Starting production server..."
    cd "$PROJECT_DIR" || exit
    npm run start
}

clean_cache() {
    print_warning "Cleaning Next.js cache and lockfiles..."
    cd "$PROJECT_DIR" || exit
    rm -rf .next
    print_success "Cache completely wiped."
}

deploy_project() {
    print_bold "=== Starting Git & Vercel Deployment ==="
    echo "Staging files for Git..."
    git add .
    
    read -p "Enter commit message (Press Enter for 'update: workspace sync'): " msg
    if [ -z "$msg" ]; then
        msg="update: workspace sync"
    fi
    
    echo "Committing: '$msg'..."
    git commit -m "$msg" || echo "No changes to commit in Git."
    
    echo "Pushing codebase to GitHub (upstream main)..."
    git push upstream main || echo "Git push failed or up to date, continuing to deployment..."
    
    echo "Deploying directly to Vercel via CLI..."
    # Deploy and capture the deployment URL; timeout after 3min so CLI never hangs
    DEPLOY_URL=$(timeout 180 npx vercel --prod --yes 2>&1 | tee /dev/stderr | grep -E 'https://vishwaleader.*\.vercel\.app' | tail -1 | tr -d '[:space:]')
    
    if [ -n "$DEPLOY_URL" ]; then
        print_success "Deployed to: $DEPLOY_URL"
        echo "Assigning production alias..."
        npx vercel alias set "$DEPLOY_URL" vishwaleader.vercel.app 2>/dev/null || true
        print_success "Alias updated: https://vishwaleader.vercel.app"
    else
        print_warning "Could not capture deployment URL automatically."
        print_warning "If checks are stuck, run: npx vercel alias set [URL] vishwaleader.vercel.app"
    fi
    
    print_success "=== Deployment Finished! ==="
}

deploy_project_local_build() {
    print_bold "=== Starting Local Build & Vercel Deployment ==="
    echo "Staging files for Git..."
    git add .
    
    read -p "Enter commit message (Press Enter for 'update: workspace sync'): " msg
    if [ -z "$msg" ]; then
        msg="update: workspace sync"
    fi
    
    echo "Committing: '$msg'..."
    git commit -m "$msg" || echo "No changes to commit in Git."
    
    echo "Pushing codebase to GitHub (upstream main)..."
    git push upstream main || echo "Git push failed or up to date, continuing to deployment..."
    
    echo "Building project locally (so you can see the terminal build)..."
    npx vercel build --prod
    
    echo "Deploying prebuilt output to Vercel..."
    npx vercel deploy --prebuilt --prod
    
    print_success "=== Deployment Finished Successfully! ==="
}

cd "$PROJECT_DIR" || exit

case "$1" in
    dev)
        start_dev
        ;;
    kill|openkill)
        openkill_port "$2"
        ;;
    build)
        build_project
        ;;
    start)
        start_prod
        ;;
    clean)
        clean_cache
        ;;
    deploy)
        deploy_project
        ;;
    view)
        if [ "$2" == "deploy" ]; then
            deploy_project_local_build
        else
            print_error "Unknown view command: $2"
            print_help
            exit 1
        fi
        ;;
    help|--help|-h|"")
        print_help
        ;;
    *)
        if [ "$1 view deploy" == "$1 $2 $3" ] && [ "$1" == "view" ]; then
            deploy_project_local_build
        else
            print_error "Unknown command: $1"
            print_help
            exit 1
        fi
        ;;
esac
